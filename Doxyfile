#------------------------------------------------------------
# Project
#------------------------------------------------------------

PROJECT_NAME           = "Wozzits Engine"
PROJECT_BRIEF          = "Experimental game engine"
PROJECT_NUMBER         = 0.1
OUTPUT_DIRECTORY       = docs/doxygen

#------------------------------------------------------------
# Input
#------------------------------------------------------------

INPUT                  = twe
FILE_PATTERNS          = *.h *.hpp
RECURSIVE              = YES

EXCLUDE_PATTERNS       = */internal/* */detail/*

#------------------------------------------------------------
# Extraction
#------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = NO

HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

#------------------------------------------------------------
# Parsing
#------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_C         = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES

#------------------------------------------------------------
# Namespaces
#------------------------------------------------------------

EXTRACT_ANON_NSPACES   = NO
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES

#------------------------------------------------------------
# Diagrams
#------------------------------------------------------------

HAVE_DOT               = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
CLASS_DIAGRAMS         = YES

#------------------------------------------------------------
# Output
#------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

#------------------------------------------------------------
# Style
#------------------------------------------------------------

JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES